{
  "name": "nursing-with-lolo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "test:run": "vitest run",
    "export:artifacts": "tsx scripts/export_artifact_content.ts",
    "generate:pdf": "npm run export:artifacts && python scripts/generate_pdfs.py",
    "generate:pptx": "npm run export:artifacts && node scripts/generate_presentations.mjs",
    "verify:content": "tsx scripts/verify-content.ts"
  },
  "dependencies": {
    "fuse.js": "7.5.0",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "recharts": "3.9.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "16.3.2",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "tsx": "^4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
